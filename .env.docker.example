# Copy to .env.docker for local Docker Compose. Values are placeholders only.
NODE_ENV="production"
APP_ENV="production"
APP_VERSION="0.1.0"
DEPLOYMENT_TARGET="docker"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT="3000"
HOSTNAME="0.0.0.0"

DATABASE_URL="postgresql://gene_prio:gene_prio_local_change_me@postgres:5432/gene_prio?schema=public"
DIRECT_URL="postgresql://gene_prio:gene_prio_local_change_me@postgres:5432/gene_prio?schema=public"

SECURITY_HEADERS_ENABLED="true"
CSP_ENABLED="true"
CSP_REPORT_ONLY="false"
TRUSTED_ORIGINS="http://localhost:3000"
ADMIN_INGEST_SECRET="replace-this-local-docker-secret"

RATE_LIMIT_ENABLED="true"
RATE_LIMIT_BACKEND="memory"
LOG_RAW_INPUTS="false"
LOG_REQUEST_BODIES="false"
AUDIT_ADMIN_ACTIONS="true"
PRIVACY_MODE_DEFAULT="true"

DISABLE_LLM="true"
LLM_PROVIDER="none"
LLM_MODEL=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

GENE_CARDS_LINKOUT_ENABLED="true"
GENE_CARDS_LICENSED_IMPORT_ENABLED="false"
GENE_CARDS_LICENSE_ACKNOWLEDGED="false"

HPO_DATA_DIR="./data/hpo"
HPO_ASSOCIATION_IMPORT_LIMIT="500"
HPO_ALLOW_NETWORK_DOWNLOADS="true"

# HPO import mode: fixture for tests/CI/local verification, full for explicit production/staging raw HPO import.
HPO_IMPORT_MODE="fixture"
