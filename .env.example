# Safe local/demo defaults. Copy to .env for local Prisma and Next.js commands.
# Never commit .env, real API keys, database credentials, patient data, or secrets.

# App/runtime
NODE_ENV="development"
APP_ENV="development"
APP_VERSION="0.1.0"
BUILD_COMMIT_SHA=""
BUILD_TIME=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT="3000"
HOSTNAME="0.0.0.0"

# Database
DATABASE_URL="file:./dev.db"
DIRECT_URL=""

# Security/admin
SECURITY_HEADERS_ENABLED="true"
CSP_ENABLED="true"
CSP_REPORT_ONLY="false"
TRUSTED_ORIGINS="http://localhost:3000"
# Replace this value in production. Production admin endpoints fail closed with this placeholder.
ADMIN_INGEST_SECRET="change-me-in-production"
MAX_JSON_BODY_BYTES="1048576"
MAX_FREE_TEXT_CHARS="8000"
MAX_HPO_TERMS="100"
MAX_CANDIDATE_GENES="500"
MAX_LITERATURE_GENES="25"
MAX_EXPORT_RESULTS="500"

# Rate limiting
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_BACKEND="memory"
RATE_LIMIT_WINDOW_SECONDS="60"
RATE_LIMIT_DEFAULT_MAX_REQUESTS="60"
RATE_LIMIT_PRIORITIZE_MAX_REQUESTS="20"
RATE_LIMIT_PHENOTYPE_EXTRACT_MAX_REQUESTS="20"
RATE_LIMIT_LITERATURE_MAX_REQUESTS="10"
RATE_LIMIT_GENE_VALIDATE_MAX_REQUESTS="30"
RATE_LIMIT_ADMIN_MAX_REQUESTS="5"
# Optional future production shared backend. Empty keeps local/dev on memory.
REDIS_URL=""

# HPO data
HPO_DATA_DIR="./data/hpo"
HPO_DOWNLOAD_TIMEOUT_MS="30000"
HPO_DOWNLOAD_RETRIES="3"
HPO_IMPORT_BATCH_SIZE="1000"
# Keep local/Codespaces SQLite imports bounded. Set empty for full production import.
HPO_ASSOCIATION_IMPORT_LIMIT="500"
HPO_ALLOW_NETWORK_DOWNLOADS="true"

# HGNC
HGNC_API_BASE_URL="https://rest.genenames.org"
HGNC_REQUEST_TIMEOUT_MS="15000"
HGNC_REQUEST_RETRIES="2"
HGNC_CACHE_TTL_SECONDS="86400"
GENE_VALIDATION_BATCH_LIMIT="200"

# PubMed / NCBI E-utilities. API key and email are optional for local development.
NCBI_EUTILS_BASE_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils"
NCBI_API_KEY=""
NCBI_EMAIL=""
NCBI_TOOL_NAME="gene-prioritizer-ai"
NCBI_REQUEST_TIMEOUT_MS="30000"
NCBI_REQUEST_RETRIES="2"
NCBI_RATE_LIMIT_RPS_NO_KEY="3"
NCBI_RATE_LIMIT_RPS_WITH_KEY="10"

# LLM optional. Disabled by default; do not expose provider keys to the browser.
LLM_PROVIDER="none"
LLM_MODEL=""
DISABLE_LLM="true"
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_REQUEST_TIMEOUT_MS="30000"
LLM_REQUEST_RETRIES="1"
LLM_MAX_INPUT_CHARS="8000"
PHENOTYPE_ALLOW_EXTERNAL_LLM="false"

# Literature
LITERATURE_ENABLED="true"
LITERATURE_DEFAULT_RETMAX="10"
LITERATURE_MAX_RETMAX="25"
LITERATURE_CACHE_TTL_SECONDS="86400"
LITERATURE_MAX_QUERY_LENGTH="500"
LITERATURE_ATTACH_TO_RANKING_DEFAULT="false"
LITERATURE_RANKING_BOOST_MAX="5"
LITERATURE_RANKING_GENE_LIMIT="5"
LITERATURE_LLM_SUMMARIES_ENABLED="false"
LITERATURE_SUMMARY_MAX_ARTICLES="5"

# GeneCards / GeneALaCart linkout and licensed import
GENE_CARDS_LINKOUT_ENABLED="true"
GENE_CARDS_LICENSED_IMPORT_ENABLED="false"
GENE_CARDS_LICENSE_ACKNOWLEDGED="false"
GENE_CARDS_IMPORT_MAX_BYTES="5242880"
GENE_CARDS_IMPORT_ALLOWED_EXTENSIONS=".csv,.tsv"
GENE_CARDS_IMPORT_REQUIRE_LICENSE_CONFIRMATION="true"
GENE_CARDS_IMPORT_STORE_RAW_FIELDS="true"
GENE_CARDS_IMPORT_MAX_ROWS="50000"
GENE_CARDS_IMPORT_ADMIN_ONLY="true"

# Deployment
DEPLOYMENT_TARGET="local"
SMOKE_BASE_URL="http://localhost:3000"
SMOKE_ADMIN_SECRET=""
SMOKE_INCLUDE_NETWORK_TESTS="false"

# Ranking and phenotype extraction
RANKING_ALGORITHM_VERSION="deterministic-hpo-v1"
RANKING_DEFAULT_LIMIT="25"
RANKING_MAX_LIMIT="100"
RANKING_CANDIDATE_GENE_LIMIT="500"
RANKING_HPO_TERM_LIMIT="100"
RANKING_STORE_RESULTS_DEFAULT="true"
RANKING_PRIVACY_MODE_DEFAULT="true"
PHENOTYPE_TEXT_MAX_CHARS="8000"
PHENOTYPE_MAX_EXTRACTED_TERMS="100"
PHENOTYPE_SEARCH_LIMIT_PER_PHRASE="10"
PHENOTYPE_REQUIRE_CONFIRMATION="true"

# Logging/privacy
LOG_LEVEL="info"
LOG_RAW_INPUTS="false"
LOG_REQUEST_BODIES="false"
AUDIT_ADMIN_ACTIONS="true"
PRIVACY_MODE_DEFAULT="true"

# Reserved future placeholders only. They are not used by current phases.
OMIM_API_KEY=""
EXOMISER_API_URL=""

# HPO import mode: fixture for tests/CI/local verification, full for explicit production/staging raw HPO import.
HPO_IMPORT_MODE="fixture"
