{
  "name": "gene-prioritizer-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Research-use foundation for an AI-assisted phenotype-to-gene prioritization application.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "tsx scripts/e2e-smoke.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run db:generate && npm run lint && npm run typecheck && npm test && npm run build && npm run format:check",
    "verify:full": "npm run db:generate && npm run db:migrate:deploy && npm run data:seed && npm run data:build-hpo && npm run lint && npm run typecheck && npm test && npm run build && npm run format:check && npm audit --audit-level=moderate && npm run test:e2e",
    "deploy:check": "tsx scripts/deployment/check-env.ts",
    "smoke:api": "tsx scripts/deployment/smoke-api.ts",
    "smoke:local": "npm run test:e2e",
    "release:check": "tsx scripts/deployment/release-check.ts && npm run deploy:check && npm run release:logres-check",
    "build:info": "tsx scripts/deployment/print-build-info.ts",
    "docker:build": "docker build -t gene-prioritizer-ai .",
    "docker:up": "docker compose --env-file .env.docker up --build",
    "docker:down": "docker compose --env-file .env.docker down",
    "db:generate": "prisma generate",
    "db:generate:postgres": "prisma generate --config=prisma/postgresql/prisma.config.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:prod": "npm run db:migrate:postgres:deploy",
    "db:migrate:postgres": "npm run db:migrate:postgres:deploy",
    "db:studio": "prisma studio",
    "data:download-hpo": "tsx scripts/download-hpo.ts",
    "data:build-hpo": "tsx scripts/build-hpo.ts",
    "data:update": "tsx scripts/update-hpo.ts",
    "data:seed": "tsx prisma/seed.ts",
    "setup": "npm run db:generate && npm run db:migrate && npm run data:seed",
    "db:migrate:postgres:deploy": "prisma migrate deploy --config=prisma/postgresql/prisma.config.ts",
    "platform:products:validate": "tsx scripts/platform/cli.ts products:validate",
    "platform:brand:validate": "tsx scripts/platform/cli.ts brand:validate",
    "platform:auth:validate": "tsx scripts/platform/cli.ts auth:validate",
    "platform:auth:configuration-check": "tsx scripts/platform/cli.ts auth:configuration-check",
    "platform:sessions:verify": "tsx scripts/platform/cli.ts sessions:verify",
    "platform:rbac:validate": "tsx scripts/platform/cli.ts rbac:validate",
    "platform:rbac:verify": "tsx scripts/platform/cli.ts rbac:verify",
    "platform:tenant-isolation:test": "tsx scripts/platform/cli.ts tenant-isolation:test",
    "platform:entitlements:validate": "tsx scripts/platform/cli.ts entitlements:validate",
    "platform:data-classification:validate": "tsx scripts/platform/cli.ts data-classification:validate",
    "platform:privacy:validate": "tsx scripts/platform/cli.ts privacy:validate",
    "platform:retention:validate": "tsx scripts/platform/cli.ts retention:validate",
    "platform:deletion:dry-run": "tsx scripts/platform/cli.ts deletion:dry-run",
    "platform:secrets:validate": "tsx scripts/platform/cli.ts secrets:validate",
    "platform:audit:verify": "tsx scripts/platform/cli.ts audit:verify",
    "platform:rate-limits:verify": "tsx scripts/platform/cli.ts rate-limits:verify",
    "platform:backup:check": "tsx scripts/platform/cli.ts backup:check",
    "platform:restore:verify": "tsx scripts/platform/cli.ts restore:verify",
    "platform:vendors:validate": "tsx scripts/platform/cli.ts vendors:validate",
    "platform:threat-model:validate": "tsx scripts/platform/cli.ts threat-model:validate",
    "platform:security:test": "tsx scripts/platform/cli.ts security:test",
    "platform:security-questionnaire:generate": "tsx scripts/platform/cli.ts security-questionnaire:generate",
    "platform:soc2:readiness": "tsx scripts/platform/cli.ts soc2:readiness",
    "platform:report": "tsx scripts/platform/cli.ts report",
    "platform:synthetic-workflow": "tsx scripts/platform/cli.ts synthetic-workflow",
    "release:logres-check": "tsx scripts/platform/cli.ts release:logres-check"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "dotenv": "^16.6.1",
    "next": "15.5.19",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
